{
  "name": "@nardole/firebase-core",
  "version": "0.0.23",
  "keywords": [
    "react",
    "mui",
    "dialog",
    "material-ui"
  ],
  "author": {
    "name": "Luiz Braga",
    "email": "me@nardole.dev"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "yarn build"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "module": "dist/main.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./esm": null
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/btmluiz/nardole-firebase",
    "directory": "packages/firebase-core"
  },
  "peerDependencies": {
    "firebase": "^12.9.0"
  },
  "devDependencies": {
    "firebase": "^12.9.0",
    "glob": "^13.0.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "packageManager": "yarn@4.10.3"
}
